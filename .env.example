# Server Configuration
NODE_ENV=development
PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
VITE_API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Supabase Auth (Google/GitHub via Supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Database
DATABASE_URL=sqlite:memory

# Insight Scout (Real AI)
OPENAI_API_KEY=sk-your-real-openai-key
OPENAI_MODEL=gpt-3.5-turbo
INSIGHT_SCOUT_REQUIRE_LIVE_AI=true

# Public demo mode (read-only)
DEMO_READ_ONLY=true
DEMO_USER_ID=demo-user
DEMO_USER_EMAIL=demo-user@local.dev
DEMO_USER_FIRST_NAME=Demo
DEMO_USER_LAST_NAME=User
