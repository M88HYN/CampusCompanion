# Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production

# Insight Scout (Real AI)
OPENAI_API_KEY=sk-your-real-openai-key
OPENAI_MODEL=gpt-3.5-turbo

# Set to true to block all fallback/mock responses and require live OpenAI
INSIGHT_SCOUT_REQUIRE_LIVE_AI=false

# Public demo mode (read-only)
DEMO_READ_ONLY=false
DEMO_USER_ID=demo-user
DEMO_USER_EMAIL=demo-user@local.dev
DEMO_USER_FIRST_NAME=Demo
DEMO_USER_LAST_NAME=User

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback
